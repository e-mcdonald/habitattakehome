# Copy to .env and adjust. Do NOT commit real secrets.

# --- Postgres (used by docker-compose to configure the postgres service) ---
POSTGRES_USER=habitat
POSTGRES_PASSWORD=habitat
POSTGRES_DB=habitat
POSTGRES_PORT=5432

# --- Pipeline runtime ------------------------------------------------------
# Native path: uncomment and point at your local Postgres.
# Docker path: docker-compose.yml overrides this to point at the compose service.
# DATABASE_URL=postgresql://habitat:habitat@localhost:5432/habitat

# prod | dev  — controls structlog rendering (JSON vs colored console).
PIPELINE_ENV=dev

# Root directory for landing/validated JSONL files. Defaults to ./data.
# PIPELINE_DATA_DIR=/app/data

# Root directory for source YAML configs. Defaults to ./sources.
# PIPELINE_SOURCES_DIR=/app/sources
